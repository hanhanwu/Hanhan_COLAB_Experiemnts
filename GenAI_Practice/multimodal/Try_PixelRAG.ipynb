      }
    },
    {
      "cell_type": "code",
      "source": [
        "import os, json, subprocess\n",
        "from pathlib import Path\n",
        "import shutil # Import shutil\n",
        "\n",
        "# System dependencies for pixelrag are now handled in an earlier setup cell (ndiD03F3SBPc).\n",
        "# Removed redundant apt-get commands from here.\n",
        "\n",
        "base = \"/content/open_ragbench/pdf/arxiv\"\n",
        "tiles_dir = Path(\"/content/pixelrag_tiles\")\n",
        "tiles_dir.mkdir(exist_ok=True)\n",
        "\n",
        "# Load pdf_urls to get arXiv PDF links\n",
        "with open(f\"{base}/pdf_urls.json\") as f:\n",
        "    pdf_urls = json.load(f)\n",
        "\n",
        "# Pick 5 papers to test with\n",
        "sample_ids = list(pdf_urls.keys())[:5]\n",
        "pdf_dir = Path(\"/tmp/sample_pdfs\")\n",
        "pdf_dir.mkdir(exist_ok=True)\n",
        "\n",
        "# Step 1: Download PDFs\n",
        "import requests\n",
        "for paper_id in sample_ids:\n",
        "    pdf_path = pdf_dir / f\"{paper_id}.pdf\"\n",
        "    if not pdf_path.exists():\n",
        "        url = pdf_urls[paper_id]\n",
        "        print(f\"Downloading {paper_id}...\")\n",
        "        r = requests.get(url, timeout=30)\n",
        "        pdf_path.write_bytes(r.content)\n",
        "\n",
        "# Find pixelshot executable\n",
        "pixelshot_path = shutil.which('pixelshot')\n",
        "if pixelshot_path is None:\n",
        "    print(\"Error: 'pixelshot' command not found. Ensure pixelrag is installed correctly and its executables are in PATH.\")\n",
        "    raise FileNotFoundError(\"'pixelshot' command not found.\")\n",
        "else:\n",
        "    print(f\"Found pixelshot at: {pixelshot_path}\")\n",
        "\n",
        "# Step 2: Render each PDF to tiles with pixelshot\n",
        "# --dpi 150  = good quality/size tradeoff for Colab storage\n",
        "for paper_id in sample_ids:\n",
        "    pdf_path = pdf_dir / f\"{paper_id}.pdf\"\n",
        "    out_dir = tiles_dir / paper_id\n",
        "    out_dir.mkdir(exist_ok=True)\n",
        "\n",
        "    print(f\"Rendering {pdf_path} to {out_dir}...\")\n",
        "    try:\n",
        "        result = subprocess.run(\n",
        "            [pixelshot_path, str(pdf_path), \"-o\", str(out_dir), \"--dpi\", \"150\"],\n",
        "            capture_output=True, text=True, check=False # Capture output and don't raise exception immediately\n",
        "        )\n",
        "        if result.returncode != 0:\n",
        "            print(f\"Error rendering {pdf_path}. Exit code: {result.returncode}\")\n",
        "            print(\"STDOUT:\", result.stdout)\n",
        "            print(\"STDERR:\", result.stderr)\n",
        "            raise subprocess.CalledProcessError(result.returncode, result.args, output=result.stdout, stderr=result.stderr)\n",
        "        else:\n",
        "            print(f\"Successfully rendered {pdf_path}\")\n",
        "            if result.stdout:\n",
        "                print(\"STDOUT:\", result.stdout)\n",
        "            if result.stderr:\n",
        "                print(\"STDERR:\", result.stderr)\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"An unexpected error occurred during pixelshot execution for {pdf_path}: {e}\")\n",
        "        raise # Re-raise the exception after printing debug info\n",
        "\n",
        "    n_tiles = len(list(out_dir.glob(\"*.png\")))\n",
        "    print(f\"  {paper_id}: {n_tiles} tiles\")\n",
        "\n",
        "print(f\"\\nAll tiles in: {tiles_dir}\")"
      ],
