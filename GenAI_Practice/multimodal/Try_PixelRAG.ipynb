      "cell_type": "code",
      "source": [
        "import json, os, base64\n",
        "from IPython.display import display, Image, HTML\n",
        "\n",
        "corpus_dir = \"/content/open_ragbench/pdf/arxiv/corpus\"\n",
        "paper_files = os.listdir(corpus_dir)\n",
