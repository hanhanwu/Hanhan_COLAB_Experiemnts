        "\n",
        "# Peek at query types (text / text-table / text-image / text-table-image)\n",
        "from collections import Counter\n",
        "source_counts = Counter(v[\"source\"] for v in queries.values())\n",
        "print(\"\\nQuery sources:\", source_counts)"
